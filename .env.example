# Copy this file to .env and fill in your values

# ── Core AI ────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Market data (TwelveData — free plan, 800 req/day) ─────────────────────────
# Get your free key at https://twelvedata.com
TWELVEDATA_API_KEY=your-twelvedata-key-here

# ── Email alerts (Microsoft Graph API — public client, no secret needed) ────────
# MS_CLIENT_ID / MS_TENANT_ID: found in Azure Portal → App registrations.
# MS_ACCOUNT_ID_PREFIX: first 8 chars of the home_account_id in ~/.m365_mcp_token_cache.json.
# MS_REFRESH_TOKEN: extracted automatically by scripts/setup_droplet.sh (or set manually).
MS_TENANT_ID=your-azure-tenant-id
MS_CLIENT_ID=your-azure-client-id
MS_ACCOUNT_ID_PREFIX=your-account-id-prefix
MS_REFRESH_TOKEN=your-refresh-token-here
ALERT_EMAIL_FROM=your-sender@example.com
ALERT_EMAIL_TO=your-recipient@example.com

# ── MT5 Bridge (optional — only needed for trade execution on Mac) ──────────────
# Auto-detected on macOS if omitted
# MT5_FILES_DIR=/Users/YOU/Library/Application Support/net.metaquotes.wine.metatrader5/drive_c/Program Files/MetaTrader 5/MQL5/Files
