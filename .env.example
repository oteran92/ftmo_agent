# Copy this file to .env and fill in your values

# ── Core AI ────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Market data (TwelveData — free plan, 800 req/day) ─────────────────────────
# Get your free key at https://twelvedata.com
TWELVEDATA_API_KEY=your-twelvedata-key-here

# ── Email alerts (Microsoft Graph API — same credentials as Outlook MCP) ───────
# Found in Azure Portal → App registrations → your app
MS_TENANT_ID=your-tenant-id
MS_CLIENT_ID=your-client-id
MS_CLIENT_SECRET=your-client-secret
ALERT_EMAIL_FROM=o.teran@silentgliss.com
ALERT_EMAIL_TO=o.teran@silentgliss.com

# ── MT5 Bridge (optional — only needed for trade execution on Mac) ──────────────
# Auto-detected on macOS if omitted
# MT5_FILES_DIR=/Users/YOU/Library/Application Support/net.metaquotes.wine.metatrader5/drive_c/Program Files/MetaTrader 5/MQL5/Files
